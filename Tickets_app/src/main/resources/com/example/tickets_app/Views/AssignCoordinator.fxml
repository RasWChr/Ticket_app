<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="400.0" spacing="10.0"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.tickets_app.GUI.Controller.AssignCoordinatorController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label fx:id="lblEventName" text="Assign Coordinators" styleClass="title" />
        <Label text="Assigned Coordinators" />
        <ListView fx:id="listAssigned" prefHeight="170.0" maxWidth="Infinity" />
        <Button mnemonicParsing="false" onAction="#onRemoveClick"
                text="Remove Selected" maxWidth="Infinity" styleClass="button-danger" />
        <Label text="Available Coordinators" />
        <ListView fx:id="listAvailable" prefHeight="170.0" maxWidth="Infinity" />
        <Button mnemonicParsing="false" onAction="#onAssignClick"
                text="Assign Selected" maxWidth="Infinity" />
        <Button mnemonicParsing="false" onAction="#onBackClick"
                text="Back" maxWidth="Infinity" />
    </children>
</VBox>