<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<VBox prefWidth="200.0" spacing="4.0" styleClass="sidebar"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.tickets_app.GUI.Controller.Misc.SidebarController">
    <padding>
        <Insets top="16.0" bottom="16.0" left="12.0" right="12.0" />
    </padding>
    <children>

        <Label text="🎟 Ticket App" styleClass="sidebar-logo" />

        <Separator styleClass="sidebar-separator" />

        <VBox styleClass="sidebar-user-block" spacing="2.0">
            <padding>
                <Insets top="8.0" bottom="8.0" left="8.0" right="8.0" />
            </padding>
            <Label fx:id="lblSidebarName" text="Loading..." styleClass="sidebar-user-name" wrapText="true" />
            <Label fx:id="lblSidebarRole" text="" styleClass="sidebar-user-role" />
        </VBox>

        <Separator styleClass="sidebar-separator" />

        <Label text="NAVIGATION" styleClass="sidebar-section-label" />

        <Button fx:id="btnSidebarEvents" text="📅  Events" onAction="#onEventsClick"
                maxWidth="Infinity" styleClass="sidebar-nav-btn" />

        <Button fx:id="btnSidebarCreateEvent" text="➕  Create Event" onAction="#onCreateEventClick"
                maxWidth="Infinity" styleClass="sidebar-nav-btn" />

        <Button fx:id="btnSidebarTicketList" text="🎫  Ticket List" onAction="#onTicketListClick"
                maxWidth="Infinity" styleClass="sidebar-nav-btn" />

        <Button fx:id="btnSidebarPrintTicket" text="🖨  Print Ticket" onAction="#onPrintTicketClick"
                maxWidth="Infinity" styleClass="sidebar-nav-btn" />

        <Separator styleClass="sidebar-separator" />

        <Label text="ADMIN" styleClass="sidebar-section-label" fx:id="lblAdminSection" />

        <Button fx:id="btnSidebarCreateUser" text="👤  Create User" onAction="#onCreateUserClick"
                maxWidth="Infinity" styleClass="sidebar-nav-btn" />

        <Button fx:id="btnSidebarManageUsers" text="👥  Manage Users" onAction="#onManageUsersClick"
                maxWidth="Infinity" styleClass="sidebar-nav-btn" />

        <Region VBox.vgrow="ALWAYS" />

        <Separator styleClass="sidebar-separator" />

        <Button text="⏻  Log Out" onAction="#onLogOutClick"
                maxWidth="Infinity" styleClass="sidebar-logout-btn" />

    </children>
</VBox>
