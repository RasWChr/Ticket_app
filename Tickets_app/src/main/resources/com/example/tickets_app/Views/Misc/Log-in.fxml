<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="400.0" spacing="6.0"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.tickets_app.GUI.Controller.Misc.LogInController">

    <padding>
        <Insets bottom="20.0" left="60.0" right="60.0" top="20.0" />
    </padding>

    <ImageView fitHeight="120.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true">
        <image>
            <Image url="@../../Images/Rat.png" />
        </image>
    </ImageView>

    <Label styleClass="title" text="Welcome" textAlignment="CENTER" />
    <Label styleClass="section-label" text="Sign in to your account" />
    <Label />

    <Label fx:id="lblError" managed="false" maxWidth="Infinity"
           styleClass="login-error-label" text="" visible="false" wrapText="true" />

    <Label text="Email" />
    <TextField fx:id="txtUN" maxWidth="Infinity" promptText="you@example.com" />

    <Label />

    <Label text="Password" />

    <!-- UPDATED PASSWORD ROW -->
    <StackPane alignment="CENTER_RIGHT" maxWidth="Infinity">

        <!-- Hidden password -->
        <PasswordField fx:id="txtPsWrd"
                       promptText="Password"
                       HBox.hgrow="ALWAYS"
                       prefHeight="36"
                       styleClass="password-field-with-button" />

        <!-- Visible password -->
        <TextField fx:id="txtPsWrdVisible"
                   promptText="Password"
                   HBox.hgrow="ALWAYS"
                   prefHeight="36"
                   visible="false"
                   managed="false"
                   styleClass="password-field-with-button" />

        <!-- Eye button INSIDE the field -->
        <Button fx:id="btnShowPassword"
                onAction="#onShowPasswordClick"
                text="👁"
                focusTraversable="false"
                styleClass="password-eye-btn" />
    </StackPane>

    <Label />

    <Button fx:id="btnLogIn" maxWidth="Infinity" onAction="#onLogInClick" text="➜]" />

</VBox>
