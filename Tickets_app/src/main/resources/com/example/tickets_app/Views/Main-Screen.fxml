<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="400.0" spacing="12.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.tickets_app.GUI.Controller.MainController">
    <padding>
        <Insets bottom="20.0" left="40.0" right="40.0" top="20.0" />
    </padding>
    <children>
        <Label fx:id="lblUser" text="User" textFill="WHITE">
         <font>
            <Font size="20.0" />
         </font></Label>
        <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@../Images/Rat.png" />
            </image>
        </ImageView>
        <Label styleClass="title" text="Main Menu" />
        <Button fx:id="btnCreateU" maxWidth="Infinity" mnemonicParsing="false" onAction="#onCreateUClick" text="Create User" />
        <Button fx:id="btnManageU" maxWidth="Infinity" mnemonicParsing="false" onAction="#onManageUClick" text="Manage Users" />
        <Button fx:id="btnEvent" maxWidth="Infinity" mnemonicParsing="false" onAction="#onEventClick" text="Events" />
        <Button fx:id="btnCreateE" maxWidth="Infinity" mnemonicParsing="false" onAction="#onCreateEClick" text="Create Event" />
        <Button fx:id="btnCreateT" maxWidth="Infinity" mnemonicParsing="false" onAction="#onCreateTClick" text="Create Ticket" />
        <Button fx:id="btnLogOut" maxWidth="Infinity" mnemonicParsing="false" onAction="#onLogOutClick" text="Log Out" />
    </children>
</VBox>
