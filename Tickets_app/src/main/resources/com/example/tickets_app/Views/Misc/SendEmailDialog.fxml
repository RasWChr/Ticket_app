<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefWidth="380.0" spacing="10.0"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.tickets_app.GUI.Controller.Misc.SendEmailController">
    <padding>
        <Insets top="24.0" bottom="24.0" left="24.0" right="24.0" />
    </padding>
    <children>
        <Label text="Send Ticket by Email" styleClass="title" />
        <Label text="Recipient Email Address" />
        <TextField fx:id="txtEmail" maxWidth="Infinity" promptText="recipient@example.com" />
        <Label fx:id="lblStatus" wrapText="true" />
        <Button fx:id="btnSend" text="Send Email" onAction="#onSendClick"
                maxWidth="Infinity" />
        <Button text="Cancel" onAction="#onCancelClick" maxWidth="Infinity" />
    </children>
</VBox>