<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="rootStack" prefHeight="600.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.tickets_app.GUI.Controller.User.NewEditUserController">

    <VBox spacing="8.0">
        <fx:include fx:id="menuBar" source="../Misc/MenuBar.fxml" />

        <VBox spacing="8.0">
            <padding><Insets bottom="20.0" left="40.0" right="40.0" top="10.0" /></padding>

            <Label styleClass="title" text="User Information" />

            <Label text="First Name" />
            <TextField fx:id="txtFirstNU" maxWidth="Infinity" />

            <Label text="Last Name" />
            <TextField fx:id="txtLastNU" maxWidth="Infinity" />

            <Label text="Email" />
            <TextField fx:id="txtEmailU" maxWidth="Infinity" />

            <Label text="Phone Number" />
            <TextField fx:id="txtPhoneU" maxWidth="Infinity" />

            <Label text="Password" />

            <!-- UPDATED PASSWORD FIELD WITH INLINE EYE BUTTON -->
            <StackPane alignment="CENTER_RIGHT" maxWidth="Infinity">

                <PasswordField fx:id="txtPassword" prefHeight="36" promptText="Password" styleClass="password-field-with-button" HBox.hgrow="ALWAYS" />

                <TextField fx:id="txtPasswordVisible" managed="false" prefHeight="36" promptText="Password" styleClass="password-field-with-button" visible="false" HBox.hgrow="ALWAYS" />

                <Button fx:id="btnShowPassword" focusTraversable="false" onAction="#onShowPasswordClick" styleClass="password-eye-btn" text="👁" />
            </StackPane>

            <Label text="Role" />

            <HBox spacing="10.0">
                <Button fx:id="btnCoordinator" maxWidth="Infinity" mnemonicParsing="false" onAction="#onCoordinatorClick" text="Coordinator" HBox.hgrow="ALWAYS" />

                <Button fx:id="btnAdmin" maxWidth="Infinity" mnemonicParsing="false" onAction="#onAdminClick" text="Admin" HBox.hgrow="ALWAYS" />
            </HBox>

            <Label />

            <Button fx:id="btnUserCE" maxWidth="Infinity" mnemonicParsing="false" onAction="#onUserCEClick" text="Create User" />
        </VBox>
    </VBox>

</StackPane>
