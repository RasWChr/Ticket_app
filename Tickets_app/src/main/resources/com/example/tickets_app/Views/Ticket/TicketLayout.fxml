<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="ticketRoot" prefWidth="420.0" spacing="0.0"
      styleClass="ticket-root"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.tickets_app.GUI.Controller.Ticket.TicketLayoutController">

    <VBox styleClass="ticket-header" spacing="4.0">
        <padding>
            <Insets top="20.0" bottom="14.0" left="24.0" right="24.0" />
        </padding>
        <Label fx:id="lblEventTitle" styleClass="ticket-event-title" wrapText="true" />
        <Label fx:id="lblTicketType" styleClass="ticket-type-badge" />
        <!-- Scope badge: shows "All Events" or the specific event name -->
        <Label fx:id="lblScope" styleClass="ticket-scope-global" wrapText="true" />
    </VBox>

    <VBox styleClass="ticket-body" spacing="14.0">
        <padding>
            <Insets top="20.0" bottom="20.0" left="24.0" right="24.0" />
        </padding>

        <VBox spacing="4.0">
            <Label text="DATE &amp; TIME" styleClass="ticket-section-label"
                   style="-fx-text-fill: #888888" />
            <Label fx:id="lblDate" styleClass="ticket-value"
                   wrapText="true" style="-fx-text-fill: #1A1A1A" />
        </VBox>

        <VBox spacing="4.0">
            <Label text="LOCATION" styleClass="ticket-section-label"
                   style="-fx-text-fill: #888888" />
            <Label fx:id="lblLocation" styleClass="ticket-value"
                   wrapText="true" style="-fx-text-fill: #1A1A1A" />
            <Label fx:id="lblLocationGuidance" styleClass="ticket-guidance"
                   wrapText="true" style="-fx-text-fill: #555555" />
        </VBox>

        <Separator styleClass="ticket-separator" />

        <!-- Customer section (hidden when no customer info) -->
        <VBox fx:id="customerSection" spacing="4.0"
              style="-fx-background-color: white;">
            <Label text="TICKET HOLDER" styleClass="ticket-section-label"
                   style="-fx-text-fill: #888888;" />
            <Label fx:id="lblCustomerName" styleClass="ticket-value"
                   style="-fx-text-fill: #1A1A1A;" />
            <Label fx:id="lblCustomerEmail" styleClass="ticket-guidance"
                   style="-fx-text-fill: #555555;" />
        </VBox>

    </VBox>

    <HBox styleClass="ticket-tearline" alignment="CENTER">
        <padding>
            <Insets top="6.0" bottom="6.0" left="24.0" right="24.0" />
        </padding>
        <Label text="- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
               styleClass="ticket-tearline-text" HBox.hgrow="ALWAYS" />
    </HBox>

    <HBox styleClass="ticket-footer" alignment="CENTER_LEFT" spacing="12.0">
        <padding>
            <Insets top="14.0" bottom="14.0" left="24.0" right="24.0" />
        </padding>
        <VBox HBox.hgrow="ALWAYS" spacing="4.0">
            <Label fx:id="lblUuid"  styleClass="ticket-uuid" />
            <Label fx:id="lblPrice" styleClass="ticket-price" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <ImageView fx:id="imgQrCode"
                   fitWidth="100.0" fitHeight="100.0"
                   preserveRatio="true" smooth="true" />
    </HBox>
    <VBox alignment="CENTER" spacing="4.0"
          style="-fx-background-color: #FFFFFF;">
        <padding>
            <Insets top="12.0" bottom="12.0" left="24.0" right="24.0" />
        </padding>
        <ImageView fx:id="imgBarcode"
                   fitWidth="360.0" fitHeight="70.0"
                   preserveRatio="false" smooth="true" />
        <Label text="SCAN TO VALIDATE"
               style="-fx-text-fill: #888888; -fx-font-size: 10px; -fx-font-weight: bold;" />
    </VBox>


</VBox>
