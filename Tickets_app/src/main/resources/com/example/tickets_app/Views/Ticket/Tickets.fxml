<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="rootStack" prefHeight="600.0" prefWidth="400.0"
           xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.tickets_app.GUI.Controller.Ticket.TicketController">

    <VBox spacing="8.0">
        <fx:include fx:id="menuBar" source="../Misc/MenuBar.fxml" />

        <VBox spacing="8.0">
            <padding>
                <Insets bottom="20.0" left="24.0" right="24.0" top="10.0" />
            </padding>

            <Label styleClass="title" text="Issue Ticket" />

            <Label text="Event" />
            <ChoiceBox fx:id="cBoxEvent" maxWidth="Infinity" />

            <Label text="Ticket Type" />
            <ChoiceBox fx:id="cBoxTickets" maxWidth="Infinity" />

            <Label text="Customer Information" styleClass="section-label"
                   style="-fx-padding: 6 0 2 0;" />

            <HBox spacing="8.0">
                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                    <Label text="First Name" />
                    <TextField fx:id="txtFirstNT" maxWidth="Infinity" />
                </VBox>
                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                    <Label text="Last Name" />
                    <TextField fx:id="txtLastNT" maxWidth="Infinity" />
                </VBox>
            </HBox>

            <Label text="Email" />
            <TextField fx:id="txtEmailT" maxWidth="Infinity"
                       promptText="customer@example.com" />

            <Label text="Phone (optional)" />
            <TextField fx:id="txtPhoneT" maxWidth="Infinity" promptText="+45 ..." />

            <Label fx:id="lblError" styleClass="login-error-label"
                   text="" visible="false" managed="false"
                   wrapText="true" maxWidth="Infinity" />

            <Label />
            <Button fx:id="btnPTicket" maxWidth="Infinity" mnemonicParsing="false"
                    onAction="#onPTicketClick" text="Issue and Preview Ticket" />
            <Button fx:id="btnCancel" maxWidth="Infinity" mnemonicParsing="false"
                    onAction="#onBtnCancelClick" text="Cancel" />
        </VBox>
    </VBox>

</StackPane>
