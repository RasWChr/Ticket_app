create table dbo.Tickets
(
    ID         int identity
        primary key,
    EventID    int
        references dbo.Events,
    Price      float,
    Discount   float,
    Tickettype varchar(50),
    UUID       nvarchar(36) default newid() not null,
    IsGlobal   bit          default 0       not null
)
