create table dbo.CustomerTickets
(
    ID         int identity
        primary key,
    TicketID   int                            not null
        references dbo.Tickets
            on delete cascade,
    EventID    int
        references dbo.Events,
    FirstName  varchar(100)                   not null,
    LastName   varchar(100)                   not null,
    Email      varchar(200)                   not null,
    Phone      varchar(30),
    IssuedAt   datetime     default getdate() not null,
    IsGlobal   bit          default 0         not null,
    TicketUUID nvarchar(36) default newid()   not null
        constraint UQ_CustomerTickets_UUID
            unique,
    IsUsed     bit          default 0         not null
)
